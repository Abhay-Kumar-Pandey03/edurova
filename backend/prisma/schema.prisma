generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model College {
  id                Int      @id @default(autoincrement())
  name              String
  location          String
  state             String
  fees              Int
  rating            Float
  placement_percent Float
  courses           String[]
  description       String
  image_url         String?
  exam_accepted     String
  min_rank          Int
  max_rank          Int
  created_at        DateTime @default(now())
}
